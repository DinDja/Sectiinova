rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userDocPath() {
      return /databases/$(database)/documents/usuarios/$(request.auth.uid);
    }

    function userExists() {
      return isSignedIn() && exists(userDocPath());
    }

    function userData() {
      return get(userDocPath()).data;
    }

    function isMentor() {
      return userExists() && (userData().perfil == 'orientador' || userData().perfil == 'coorientador');
    }

    function isMyClub(clubeId) {
      return userExists() && userData().clube_id == clubeId;
    }

    function projectBelongsToClub(projectId, clubeId) {
      return exists(/databases/$(database)/documents/projetos/$(projectId))
        && get(/databases/$(database)/documents/projetos/$(projectId)).data.clube_id == clubeId;
    }

    function isExternalMember(clubeId) {
      return isSignedIn() && exists(/databases/$(database)/documents/forum_membros_externos/$(request.auth.uid))
        && get(/databases/$(database)/documents/forum_membros_externos/$(request.auth.uid)).data.clube_id == clubeId;
    }

    match /clubes_ciencia/{clubeId} {
      allow read: if true;
      allow create, update, delete: if belongsToClub(clubeId);
    }

    match /diario_bordo/{entryId} {
      allow read: if true;

      allow create: if (isMentor() || isMyClub(request.resource.data.clube_id))
        && request.resource.data.clube_id is string
        && request.resource.data.projeto_id is string
        && projectBelongsToClub(request.resource.data.projeto_id, request.resource.data.clube_id);

      allow update: if (isMentor() || isMyClub(resource.data.clube_id))
        && resource.data.clube_id is string
        && resource.data.projeto_id is string
        && request.resource.data.clube_id == resource.data.clube_id
        && request.resource.data.projeto_id == resource.data.projeto_id
        && projectBelongsToClub(resource.data.projeto_id, resource.data.clube_id);

      allow delete: if (isMentor() || isMyClub(resource.data.clube_id))
        && resource.data.clube_id is string
        && resource.data.projeto_id is string
        && projectBelongsToClub(resource.data.projeto_id, resource.data.clube_id);
    }

    function isProjectOrientador(resource) {
      return resource.data.orientador_ids is list && request.auth != null
        && request.auth.uid in resource.data.orientador_ids;
    }

    match /projetos/{projectId} {
      allow read: if true;

      allow create: if (isMentor() || isMyClub(request.resource.data.clube_id))
        && request.resource.data.titulo is string
        && request.resource.data.clube_id is string
        && request.resource.data.escola_id is string
        && request.resource.data.createdAt is timestamp
        && (request.resource.data.imagens is list ? request.resource.data.imagens.size() <= 2 : true);

      allow update: if (isMentor() || isMyClub(resource.data.clube_id) || isProjectOrientador(resource))
        && resource.data.clube_id is string
        && request.resource.data.clube_id == resource.data.clube_id;

      allow delete: if (isMentor() || isMyClub(resource.data.clube_id) || isProjectOrientador(resource))
        && resource.data.clube_id is string;
    }

    match /usuarios/{userId} {
      allow read: if true;
      // Permite que cada usuário gerencie seu próprio documento de perfil.
      // Inclui permissões para gerenciar sidebarOrder (ordem de navegação personalizada).
      allow create, update, delete: if request.auth != null && request.auth.uid == userId;
    }

    match /unidades_escolares/{schoolId} {
      allow read: if true;
      allow write: if false;
    }

    // ─── Fórum: Tópicos ──────────────────────────────────
    match /forum_topicos/{topicId} {
      allow read: if true;

      allow create: if isSignedIn()
        && request.resource.data.clube_id is string
        && request.resource.data.titulo is string
        && request.resource.data.autor_id == request.auth.uid
        && (
          isMyClub(request.resource.data.clube_id)
          || isExternalMember(request.resource.data.clube_id)
        );

      // Mentor ou autor do tópico podem atualizar tudo
      // Qualquer usuário autenticado pode atualizar contadores (validação server-side)
      allow update: if isSignedIn() && (
        (isMentor() && isMyClub(resource.data.clube_id))
        || request.auth.uid == resource.data.autor_id
        || request.resource.data.clube_id == resource.data.clube_id // Permitir qualquer update mantendo o clube
      );

      allow delete: if isSignedIn()
        && (
          (isMentor() && isMyClub(resource.data.clube_id))
          || isExternalMember(resource.data.clube_id)
        );
    }

    // ─── Fórum: Mensagens ────────────────────────────────
    match /forum_mensagens/{msgId} {
      allow read: if true;

      // Criar mensagens: apenas usuários autenticados (validação server-side)
      // O servidor valida permissões, bans, suspensões, mutações, etc.
      allow create: if isSignedIn()
        && request.resource.data.topico_id is string
        && request.resource.data.clube_id is string
        && request.resource.data.autor_id is string
        && request.resource.data.conteudo is string
        && request.resource.data.createdAt is timestamp;

      // Editar: apenas o autor, mentor do clube, ou membro externo do clube
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.autor_id
        || (isMentor() && isMyClub(resource.data.clube_id))
        || isExternalMember(resource.data.clube_id)
      );

      // Deletar: apenas o autor, mentor do clube, ou membro externo do clube
      allow delete: if isSignedIn() && (
        request.auth.uid == resource.data.autor_id
        || (isMentor() && isMyClub(resource.data.clube_id))
        || isExternalMember(resource.data.clube_id)
      );
    }

    // ─── Fórum: Estado de Moderação ──────────────────────
    match /forum_user_moderation_state/{docId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isMentor();
    }

    // ─── Fórum: Silenciamentos de Tópicos ────────────────
    match /forum_topic_mutes/{docId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isMentor();
    }

    // ─── Fórum: Solicitações de Entrada ──────────────────
    match /forum_solicitacoes/{reqId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && request.resource.data.solicitante_id == request.auth.uid
        && request.resource.data.clube_id is string;

      allow update: if isSignedIn()
        && isMentor()
        && isMyClub(resource.data.clube_id);
    }

    // ─── Fórum: Membros Externos ─────────────────────────
    match /forum_membros_externos/{memId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && isMentor()
        && isMyClub(request.resource.data.clube_id);

      allow delete: if isSignedIn()
        && isMentor()
        && isMyClub(resource.data.clube_id);
    }

    // ─── Fórum: Mensagens Excluídas (Auditoria) ──────────
    match /forum_mensagens_excluidas/{docId} {
      allow read: if isSignedIn() && isMentor();

      allow create: if isSignedIn();

      allow update, delete: if false;
    }

    // ─── Fórum: Logs de Auditoria ──────────────────────
    match /forum_audit_logs/{logId} {
      allow read: if isSignedIn() && isMentor();

      allow create: if isSignedIn();

      allow update, delete: if false;
    }

    // ─── Fórum: Alertas de Moderação para Mentores ─────
    match /forum_moderation_alerts/{alertId} {
      allow read: if isSignedIn()
        && (
          request.auth.uid == resource.data.recipient_id
          || (isMentor() && isMyClub(resource.data.clube_id))
        );

      allow update: if isSignedIn()
        && (
          request.auth.uid == resource.data.recipient_id
          || (isMentor() && isMyClub(resource.data.clube_id))
        )
        && request.resource.data.recipient_id == resource.data.recipient_id
        && request.resource.data.clube_id == resource.data.clube_id;

      allow create, delete: if false;
    }

    match /{document=**} {
      allow read: if false;
      allow write: if false;
    }
  }
} 