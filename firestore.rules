rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userDocPath() {
      return /databases/$(database)/documents/usuarios/$(request.auth.uid);
    }

    function userExists() {
      return isSignedIn() && exists(userDocPath());
    }

    function userData() {
      return get(userDocPath()).data;
    }

    function clubDocPath(clubeId) {
      return /databases/$(database)/documents/clubes/$(clubeId);
    }

    function clubLegacyDocPath(clubeId) {
      return /databases/$(database)/documents/clubes_ciencia/$(clubeId);
    }

    function clubExistsPrimary(clubeId) {
      return exists(clubDocPath(clubeId));
    }

    function clubExistsLegacy(clubeId) {
      return exists(clubLegacyDocPath(clubeId));
    }

    function clubExists(clubeId) {
      return clubExistsPrimary(clubeId) || clubExistsLegacy(clubeId);
    }

    function clubData(clubeId) {
      return clubExistsPrimary(clubeId)
        ? get(clubDocPath(clubeId)).data
        : get(clubLegacyDocPath(clubeId)).data;
    }

    function isMySchool(escolaId) {
      return userExists() && (
        (userData().escolas_ids is list && escolaId in userData().escolas_ids)
        || userData().escola_id == escolaId
      );
    }

    function isMySchoolLegacyAware(escolaId, escolaNome) {
      return isMySchool(escolaId)
        || (
          userExists()
          && escolaNome is string
          && escolaNome.size() > 0
          && (
            userData().escola_nome == escolaNome
            || (userData().escolas_nomes is list && escolaNome in userData().escolas_nomes)
          )
        );
    }

    function isClubDocMember(clubeId) {
      return isSignedIn()
        && clubExists(clubeId)
        && (
          (clubData(clubeId).membros_ids is list && request.auth.uid in clubData(clubeId).membros_ids)
          || (clubData(clubeId).clubistas_ids is list && request.auth.uid in clubData(clubeId).clubistas_ids)
          || (clubData(clubeId).orientador_ids is list && request.auth.uid in clubData(clubeId).orientador_ids)
          || (clubData(clubeId).orientadores_ids is list && request.auth.uid in clubData(clubeId).orientadores_ids)
          || (clubData(clubeId).coorientador_ids is list && request.auth.uid in clubData(clubeId).coorientador_ids)
          || (clubData(clubeId).coorientadores_ids is list && request.auth.uid in clubData(clubeId).coorientadores_ids)
          || clubData(clubeId).mentor_id == request.auth.uid
        );
    }

    function isClubTeacherMember(clubeId) {
      return isSignedIn()
        && isMentor()
        && clubeId is string
        && clubeId.size() > 0
        && (
          (
            userData().clubes_ids is list
            && clubeId in userData().clubes_ids
          )
          || userData().clube_id == clubeId
          || isClubDocMember(clubeId)
        );
    }

    function hasClubMinimumStructure(data) {
      return data.orientador_ids is list
        && data.orientador_ids.size() >= 1
        && request.auth.uid in data.orientador_ids
        && data.clubistas_ids is list
        && data.membros_ids is list
        && request.auth.uid in data.membros_ids;
    }

    function isStudentProfile(perfil) {
      return perfil == 'estudante' || perfil == 'investigador' || perfil == 'aluno';
    }

    function isMentorProfile(perfil) {
      return perfil == 'orientador' || perfil == 'coorientador';
    }

    function isAllowedProfile(perfil) {
      return isStudentProfile(perfil) || isMentorProfile(perfil);
    }

    function isMentorDomainEmail(email) {
      return email is string
        && email.matches('.*@enova\\.educacao\\.ba\\.gov\\.br$');
    }

    function hasValidUserProfileShapeOnCreate(userId) {
      return request.resource.data.uid == userId
        && request.resource.data.email is string
        && request.resource.data.perfil is string
        && isAllowedProfile(request.resource.data.perfil)
        && (
          !(request.auth.token.email is string)
          || request.resource.data.email == request.auth.token.email
        )
        && request.resource.data.clubes_ids is list
        && request.resource.data.escolas_ids is list
        && request.resource.data.createdAt is timestamp;
    }

    function isSafeSelfProfileUpdate(userId) {
      return request.auth != null
        && request.auth.uid == userId
        && isUiPreferencesChangeValid()
        && isSidebarOrderChangeValid()
        && isPopEventosSavedChangeValid()
        && isPopEventosAlertsChangeValid()
        && isLibrarySavedBooksChangeValid()
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'nome',
          'telefone',
          'lattes',
          'bio',
          'localizacao',
          'fotoBase64',
          'lattes_data',
          'ui_preferences',
          'sidebarOrder',
          'pop_eventos_saved',
          'pop_eventos_alert_subscriptions',
          'pop_eventos_alert_subscriptions_count',
          'library_saved_books'
        ]);
    }

    function isUiPreferencesChangeValid() {
      return !request.resource.data.diff(resource.data).changedKeys().hasAny(['ui_preferences'])
        || hasValidUiPreferences(request.resource.data);
    }

    function isSidebarOrderChangeValid() {
      return !request.resource.data.diff(resource.data).changedKeys().hasAny(['sidebarOrder'])
        || isValidSidebarOrder(request.resource.data);
    }

    function isPopEventosSavedChangeValid() {
      return !request.resource.data.diff(resource.data).changedKeys().hasAny(['pop_eventos_saved'])
        || hasValidPopEventosSaved(request.resource.data);
    }

    function isPopEventosAlertsChangeValid() {
      return !request.resource.data.diff(resource.data).changedKeys().hasAny([
          'pop_eventos_alert_subscriptions',
          'pop_eventos_alert_subscriptions_count'
        ])
        || hasValidPopEventosAlertSubscriptions(request.resource.data);
    }

    function isLibrarySavedBooksChangeValid() {
      return !request.resource.data.diff(resource.data).changedKeys().hasAny(['library_saved_books'])
        || hasValidLibrarySavedBooks(request.resource.data);
    }

    function schoolChangeCountFromData(data) {
      return data.school_change_count is int ? data.school_change_count : 0;
    }

 function hasValidUiPreferences(data) {
  return (
    !(data.ui_preferences is map)
    || (
      data.ui_preferences.keys().hasOnly(['font_id', 'theme_id', 'style_id'])
      && (
        !(data.ui_preferences.font_id is string)
        || data.ui_preferences.font_id.size() > 0
      )
      && (
        !(data.ui_preferences.theme_id is string)
        || data.ui_preferences.theme_id.size() > 0
      )
      && (
        !(data.ui_preferences.style_id is string)
        || data.ui_preferences.style_id.size() > 0
      )
    )
  );
}

    function hasValidPopEventosSaved(data) {
      return !(data.pop_eventos_saved is list)
        || data.pop_eventos_saved.size() <= 80;
    }

    function hasValidLibrarySavedBooks(data) {
      return !(data.library_saved_books is list)
        || data.library_saved_books.size() <= 80;
    }

    function hasValidPopEventosAlertSubscriptions(data) {
      let hasSubscriptionsList = data.pop_eventos_alert_subscriptions is list;
      let hasSubscriptionsCount = data.pop_eventos_alert_subscriptions_count is int;
      let subscriptionsSize = hasSubscriptionsList ? data.pop_eventos_alert_subscriptions.size() : 0;
      let subscriptionsCount = hasSubscriptionsCount ? data.pop_eventos_alert_subscriptions_count : 0;

      return (
        !hasSubscriptionsList
        || subscriptionsSize <= 120
      )
      && (
        !hasSubscriptionsCount
        || (
          subscriptionsCount >= 0
          && subscriptionsCount <= 120
        )
      )
      && (
        !hasSubscriptionsList
        || !hasSubscriptionsCount
        || subscriptionsCount == subscriptionsSize
      );
    }

    function isValidSidebarOrder(data) {
      return !(data.sidebarOrder is list)
        || (
          data.sidebarOrder.size() >= 0
          && data.sidebarOrder.size() <= 8
          && (
            data.sidebarOrder.size() == 0
            || data.sidebarOrder.size() == 1
              && data.sidebarOrder[0] is string
            || data.sidebarOrder.size() == 2
              && data.sidebarOrder[0] is string
              && data.sidebarOrder[1] is string
            || data.sidebarOrder.size() == 3
              && data.sidebarOrder[0] is string
              && data.sidebarOrder[1] is string
              && data.sidebarOrder[2] is string
            || data.sidebarOrder.size() == 4
              && data.sidebarOrder[0] is string
              && data.sidebarOrder[1] is string
              && data.sidebarOrder[2] is string
              && data.sidebarOrder[3] is string
            || data.sidebarOrder.size() == 5
              && data.sidebarOrder[0] is string
              && data.sidebarOrder[1] is string
              && data.sidebarOrder[2] is string
              && data.sidebarOrder[3] is string
              && data.sidebarOrder[4] is string
            || data.sidebarOrder.size() == 6
              && data.sidebarOrder[0] is string
              && data.sidebarOrder[1] is string
              && data.sidebarOrder[2] is string
              && data.sidebarOrder[3] is string
              && data.sidebarOrder[4] is string
              && data.sidebarOrder[5] is string
            || data.sidebarOrder.size() == 7
              && data.sidebarOrder[0] is string
              && data.sidebarOrder[1] is string
              && data.sidebarOrder[2] is string
              && data.sidebarOrder[3] is string
              && data.sidebarOrder[4] is string
              && data.sidebarOrder[5] is string
              && data.sidebarOrder[6] is string
            || data.sidebarOrder.size() == 8
              && data.sidebarOrder[0] is string
              && data.sidebarOrder[1] is string
              && data.sidebarOrder[2] is string
              && data.sidebarOrder[3] is string
              && data.sidebarOrder[4] is string
              && data.sidebarOrder[5] is string
              && data.sidebarOrder[6] is string
              && data.sidebarOrder[7] is string
          )
        );
    }

    function hasNoClubLinksInData(data) {
      return (
        !(data.clube_id is string)
        || data.clube_id.size() == 0
      )
      && (
        !(data.clubes_ids is list)
        || data.clubes_ids.size() == 0
      );
    }

    function isCanonicalSchoolListForSelfCorrection() {
      return request.resource.data.escolas_ids is list
        && request.resource.data.escolas_ids.size() == 1
        && request.resource.data.escola_id is string
        && request.resource.data.escola_id.size() > 0
        && request.resource.data.escolas_ids[0] == request.resource.data.escola_id;
    }

    function canSelfCorrectSchool(userId) {
      return request.auth != null
        && request.auth.uid == userId
        && resource.data.perfil is string
        && isAllowedProfile(resource.data.perfil)
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.email == resource.data.email
        && request.resource.data.perfil == resource.data.perfil
        && request.resource.data.rede_administrativa == resource.data.rede_administrativa
        && request.resource.data.clube_id == resource.data.clube_id
        && request.resource.data.clubes_ids == resource.data.clubes_ids
        && hasNoClubLinksInData(resource.data)
        && hasNoClubLinksInData(request.resource.data)
        && request.resource.data.escola_id is string
        && request.resource.data.escola_id.size() > 0
        && request.resource.data.escola_id != resource.data.escola_id
        && request.resource.data.escola_nome is string
        && request.resource.data.escola_nome.size() > 0
        && request.resource.data.escola_municipio is string
        && request.resource.data.escola_uf is string
        && request.resource.data.escola_uf.size() > 0
        && isCanonicalSchoolListForSelfCorrection()
        && request.resource.data.school_change_count is int
        && request.resource.data.school_change_count == schoolChangeCountFromData(resource.data) + 1
        && request.resource.data.school_change_count <= 1
        && request.resource.data.school_change_last_reason is string
        && request.resource.data.school_change_last_reason.size() >= 10
        && request.resource.data.school_change_last_reason.size() <= 240
        && request.resource.data.school_change_last_at is timestamp
        && request.resource.data.school_change_last_at == request.time
        && isUiPreferencesChangeValid()
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'nome',
          'telefone',
          'lattes',
          'bio',
          'localizacao',
          'fotoBase64',
          'lattes_data',
          'ui_preferences',
          'escola_id',
          'escola_nome',
          'escola_municipio',
          'escola_uf',
          'escolas_ids',
          'school_change_count',
          'school_change_last_reason',
          'school_change_last_at'
        ]);
    }

    function hasNoClubInProfile() {
      return userExists()
        && (
          !(userData().clube_id is string)
          || userData().clube_id.size() == 0
        )
        && (
          !(userData().clubes_ids is list)
          || userData().clubes_ids.size() == 0
        );
    }

    function userIsInSchool(data, escolaId, escolaNome) {
      return data.escola_id == escolaId
        || (data.escolas_ids is list && escolaId in data.escolas_ids)
        || (
          escolaNome is string
          && escolaNome.size() > 0
          && (
            data.escola_nome == escolaNome
            || (data.escolas_nomes is list && escolaNome in data.escolas_nomes)
          )
        );
    }

    function canMentorManageStudentClub(clubeId, studentData) {
      return clubeId is string
        && clubeId.size() > 0
        && clubExists(clubeId)
        && isClubTeacherMember(clubeId)
        && userIsInSchool(
          studentData,
          clubData(clubeId).escola_id,
          clubData(clubeId).escola_nome
        );
    }

    function canMentorLinkStudentToClub() {
      return isSignedIn()
        && isMentor()
        && resource.data.perfil is string
        && isStudentProfile(resource.data.perfil)
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['clube_id', 'clubes_ids'])
        && request.resource.data.clube_id is string
        && request.resource.data.clubes_ids is list
        && (
          request.resource.data.clube_id.size() == 0
          || request.resource.data.clube_id in request.resource.data.clubes_ids
        )
        && (
          request.resource.data.clube_id.size() > 0
          || request.resource.data.clubes_ids.size() == 0
        )
        && (
          canMentorManageStudentClub(request.resource.data.clube_id, resource.data)
          || canMentorManageStudentClub(resource.data.clube_id, resource.data)
        )
        && (
          resource.data.clubes_ids is list
          ? request.resource.data.clubes_ids.size() <= resource.data.clubes_ids.size() + (
            resource.data.clube_id is string
            && resource.data.clube_id.size() > 0
            && !(resource.data.clube_id in resource.data.clubes_ids)
            ? 2
            : 1
          )
          : request.resource.data.clubes_ids.size() <= (
            resource.data.clube_id is string
            && resource.data.clube_id.size() > 0
            ? 2
            : 1
          )
        )
        && (
          !(resource.data.clubes_ids is list)
          || request.resource.data.clubes_ids.size() + 1 >= resource.data.clubes_ids.size()
        );
    }

    function isMentor() {
      return isSignedIn() && (
        (
          userExists()
          && userData().perfil is string
          && isMentorProfile(userData().perfil)
        )
        || (
          request.auth.token.email is string
          && isMentorDomainEmail(request.auth.token.email)
        )
      );
    }

    function isMyClub(clubeId) {
      return (
        userExists() && (
          (userData().clubes_ids is list && clubeId in userData().clubes_ids)
          || userData().clube_id == clubeId
        )
      ) || isClubDocMember(clubeId);
    }

    function projectBelongsToClub(projectId, clubeId) {
      return exists(/databases/$(database)/documents/projetos/$(projectId))
        && get(/databases/$(database)/documents/projetos/$(projectId)).data.clube_id == clubeId;
    }

    function isProjectMemberFromData(data) {
      return isSignedIn() && (
        (data.membros_ids is list && request.auth.uid in data.membros_ids)
        || (data.orientador_ids is list && request.auth.uid in data.orientador_ids)
        || (data.orientadores_ids is list && request.auth.uid in data.orientadores_ids)
        || (data.coorientador_ids is list && request.auth.uid in data.coorientador_ids)
        || (data.coorientadores_ids is list && request.auth.uid in data.coorientadores_ids)
        || (data.investigadores_ids is list && request.auth.uid in data.investigadores_ids)
        || data.orientador_id == request.auth.uid
        || data.coorientador_id == request.auth.uid
        || data.mentor_id == request.auth.uid
        || data.autor_id == request.auth.uid
        || data.author_id == request.auth.uid
        || data.createdBy == request.auth.uid
        || data.created_by == request.auth.uid
        || data.criador_id == request.auth.uid
        || data.creator_id == request.auth.uid
        || data.owner_id == request.auth.uid
        || (
          data.clube_id is string
          && isClubTeacherMember(data.clube_id)
        )
      );
    }

    function isProjectMember(projectId) {
      return projectId is string
        && projectId.size() > 0
        && exists(/databases/$(database)/documents/projetos/$(projectId))
        && isProjectMemberFromData(get(/databases/$(database)/documents/projetos/$(projectId)).data);
    }

    function safeProjectLikesByUser(data) {
      return data.likes_by_user is map ? data.likes_by_user : {};
    }

    function projectLikesCount(data) {
      return data.likes_count is int
        ? data.likes_count
        : (
          data.likes is int
          ? data.likes
          : 0
        );
    }

    function isProjectLikeUpdatedAtValid() {
      return !request.resource.data.diff(resource.data).changedKeys().hasAny(['updatedAt'])
        || (
          request.resource.data.updatedAt is timestamp
          && request.resource.data.updatedAt == request.time
        );
    }

    function projectLikeKeyChangedByCurrentUserOnly() {
      return request.resource.data.likes_by_user.diff(safeProjectLikesByUser(resource.data))
        .affectedKeys()
        .hasOnly([request.auth.uid]);
    }

    function canToggleProjectLike() {
      let currentLikesByUser = safeProjectLikesByUser(resource.data);
      let nextLikesByUser = request.resource.data.likes_by_user is map ? request.resource.data.likes_by_user : {};
      let hadLike = currentLikesByUser[request.auth.uid] == true;
      let hasLike = nextLikesByUser[request.auth.uid] == true;
      let hasLikeKey = nextLikesByUser.keys().hasAny([request.auth.uid]);
      let currentLikesCount = projectLikesCount(resource.data);

      return isSignedIn()
        && resource.data.clube_id is string
        && request.resource.data.clube_id == resource.data.clube_id
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'likes_by_user',
          'likes_count',
          'updatedAt'
        ])
        && request.resource.data.likes_by_user is map
        && request.resource.data.likes_count is int
        && currentLikesCount >= 0
        && request.resource.data.likes_count >= 0
        && isProjectLikeUpdatedAtValid()
        && projectLikeKeyChangedByCurrentUserOnly()
        && (
          (
            !hadLike
            && hasLike
            && hasLikeKey
            && request.resource.data.likes_count == currentLikesCount + 1
          )
          || (
            hadLike
            && !hasLike
            && !hasLikeKey
            && request.resource.data.likes_count == currentLikesCount - 1
          )
        );
    }

    function isExternalMember(clubeId) {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/forum_membros_externos/$(clubeId + "__" + request.auth.uid))
        || (
          exists(/databases/$(database)/documents/forum_membros_externos/$(request.auth.uid))
          && get(/databases/$(database)/documents/forum_membros_externos/$(request.auth.uid)).data.clube_id == clubeId
        )
      );
    }

    function isSupportPriority(priority) {
      return priority == 'baixa'
        || priority == 'media'
        || priority == 'alta'
        || priority == 'critica';
    }

    function isSupportStatus(status) {
      return status == 'aberto'
        || status == 'em_analise'
        || status == 'resolvido'
        || status == 'arquivado';
    }

    function hasValidSupportTicketCreate() {
      return request.resource.data.keys().hasAll([
          'module_id',
          'module_label',
          'description',
          'priority',
          'status',
          'reporter_uid',
          'reporter_email',
          'platform',
          'source',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.keys().hasOnly([
          'module_id',
          'module_label',
          'description',
          'priority',
          'status',
          'reporter_uid',
          'reporter_nome',
          'reporter_email',
          'contact_email',
          'context_clube_nome',
          'page_url',
          'browser_ua',
          'platform',
          'source',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.module_id is string
        && request.resource.data.module_id.size() > 0
        && request.resource.data.module_id.size() <= 64
        && request.resource.data.module_label is string
        && request.resource.data.module_label.size() > 0
        && request.resource.data.module_label.size() <= 120
        && request.resource.data.description is string
        && request.resource.data.description.size() >= 15
        && request.resource.data.description.size() <= 4000
        && request.resource.data.priority is string
        && isSupportPriority(request.resource.data.priority)
        && request.resource.data.status == 'aberto'
        && request.resource.data.reporter_uid == request.auth.uid
        && request.resource.data.reporter_email is string
        && request.resource.data.reporter_email.size() > 5
        && request.resource.data.reporter_email.size() <= 160
        && (
          !(request.auth.token.email is string)
          || request.resource.data.reporter_email == request.auth.token.email
        )
        && (
          !(request.resource.data.reporter_nome is string)
          || request.resource.data.reporter_nome.size() <= 160
        )
        && (
          !(request.resource.data.contact_email is string)
          || request.resource.data.contact_email.size() <= 160
        )
        && (
          !(request.resource.data.context_clube_nome is string)
          || request.resource.data.context_clube_nome.size() <= 180
        )
        && (
          !(request.resource.data.page_url is string)
          || request.resource.data.page_url.size() <= 500
        )
        && (
          !(request.resource.data.browser_ua is string)
          || request.resource.data.browser_ua.size() <= 400
        )
        && request.resource.data.platform == 'web'
        && request.resource.data.source == 'support_widget'
        && request.resource.data.createdAt is timestamp
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt is timestamp
        && request.resource.data.updatedAt == request.time;
    }

    function canReadSupportTicket() {
      return isSignedIn()
        && (
          request.auth.uid == resource.data.reporter_uid
          || isMentor()
        );
    }

    match /support_tickets/{ticketId} {
      allow read: if canReadSupportTicket();

      allow create: if isSignedIn()
        && userExists()
        && hasValidSupportTicketCreate();

      allow update: if isSignedIn()
        && isMentor()
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'status',
          'updatedAt'
        ])
        && request.resource.data.status is string
        && isSupportStatus(request.resource.data.status)
        && request.resource.data.updatedAt is timestamp
        && request.resource.data.updatedAt == request.time;

      allow delete: if false;
    }

    match /clubes/{clubeId} {
      allow read: if true;
      allow create: if isMentor()
        && request.resource.data.id == clubeId
        && request.resource.data.nome is string
        && request.resource.data.escola_id is string
        && isMySchoolLegacyAware(request.resource.data.escola_id, request.resource.data.escola_nome)
        && hasClubMinimumStructure(request.resource.data);
      allow update: if isClubTeacherMember(clubeId)
        && request.resource.data.mentor_id == resource.data.mentor_id
        && (
          !(resource.data.orientador_ids is list)
          || !(resource.data.mentor_id in resource.data.orientador_ids)
          || (
            request.resource.data.orientador_ids is list
            && resource.data.mentor_id in request.resource.data.orientador_ids
          )
        )
        && (
          !(resource.data.membros_ids is list)
          || !(resource.data.mentor_id in resource.data.membros_ids)
          || (
            request.resource.data.membros_ids is list
            && resource.data.mentor_id in request.resource.data.membros_ids
          )
        );
      allow delete: if isClubTeacherMember(clubeId);
    }

    match /clubes/{clubeId}/documentos_chunks/{chunkId} {
      allow read: if true;
      allow create: if isMentor()
        && (
          !clubExists(clubeId)
          || isClubTeacherMember(clubeId)
        );
      allow update, delete: if isClubTeacherMember(clubeId);
    }

    match /clubes_ciencia/{clubeId} {
      allow read: if true;
      allow create, update, delete: if isMyClub(clubeId);
    }

    match /diario_bordo/{entryId} {
      allow read: if resource.data.projeto_id is string
        && isProjectMember(resource.data.projeto_id);

      allow create: if request.resource.data.clube_id is string
        && request.resource.data.projeto_id is string
        && isProjectMember(request.resource.data.projeto_id)
        && projectBelongsToClub(request.resource.data.projeto_id, request.resource.data.clube_id);

      allow update: if resource.data.clube_id is string
        && resource.data.projeto_id is string
        && isProjectMember(resource.data.projeto_id)
        && request.resource.data.clube_id == resource.data.clube_id
        && request.resource.data.projeto_id == resource.data.projeto_id
        && projectBelongsToClub(resource.data.projeto_id, resource.data.clube_id);

      allow delete: if resource.data.clube_id is string
        && resource.data.projeto_id is string
        && isProjectMember(resource.data.projeto_id)
        && projectBelongsToClub(resource.data.projeto_id, resource.data.clube_id);
    }

    function isProjectOrientador(resource) {
      return resource.data.orientador_ids is list && request.auth != null
        && request.auth.uid in resource.data.orientador_ids;
    }

    match /projetos/{projectId} {
      allow read: if true;

      allow create: if request.resource.data.clube_id is string
        && request.resource.data.clube_id.size() > 0
        && isClubTeacherMember(request.resource.data.clube_id);

      allow update: if (
          (isMentor() || isMyClub(resource.data.clube_id) || isProjectOrientador(resource))
          && resource.data.clube_id is string
          && request.resource.data.clube_id == resource.data.clube_id
        )
        || canToggleProjectLike();

      allow delete: if isMentor()
        && resource.data.clube_id is string
        && (
          isProjectOrientador(resource)
          || (resource.data.orientadores_ids is list && request.auth.uid in resource.data.orientadores_ids)
          || resource.data.orientador_id == request.auth.uid
          || (resource.data.coorientador_ids is list && request.auth.uid in resource.data.coorientador_ids)
          || (resource.data.coorientadores_ids is list && request.auth.uid in resource.data.coorientadores_ids)
          || resource.data.coorientador_id == request.auth.uid
          || resource.data.mentor_id == request.auth.uid
          || resource.data.autor_id == request.auth.uid
          || resource.data.author_id == request.auth.uid
          || resource.data.createdBy == request.auth.uid
          || resource.data.created_by == request.auth.uid
          || resource.data.criador_id == request.auth.uid
          || resource.data.creator_id == request.auth.uid
          || resource.data.owner_id == request.auth.uid
        );
    }

    match /usuarios/{userId} {
      allow read: if true;
      // Permite que cada usuário gerencie seu próprio documento de perfil.
      // Inclui permissões para gerenciar sidebarOrder (ordem de navegação personalizada).
      allow create: if request.auth != null
        && request.auth.uid == userId
        && hasValidUserProfileShapeOnCreate(userId);
      allow delete: if false;
      allow update: if isSafeSelfProfileUpdate(userId)
        || canSelfCorrectSchool(userId)
        || canMentorLinkStudentToClub();
    }

    match /unidades_escolares/{schoolId} {
      allow read: if true;
      allow write: if false;
    }

    match /clube_solicitacoes/{reqId} {
      allow read: if isSignedIn()
        && (
          resource.data.solicitante_id == request.auth.uid
          || (isMentor() && isMyClub(resource.data.clube_id))
        );

      allow create: if isSignedIn()
        && userExists()
        && (
          (isStudentProfile(userData().perfil) && hasNoClubInProfile())
          || isMentorProfile(userData().perfil)
        )
        && request.resource.data.clube_id is string
        && request.resource.data.clube_id.size() > 0
        && clubExists(request.resource.data.clube_id)
        && isMySchool(clubData(request.resource.data.clube_id).escola_id)
        && request.resource.data.solicitante_id == request.auth.uid
        && request.resource.data.status == 'pendente';

      allow update: if isSignedIn()
        && isMentor()
        && (
          isMyClub(resource.data.clube_id)
          || (
            resource.data.escola_id is string
            && resource.data.escola_id.size() > 0
            && isMySchool(resource.data.escola_id)
          )
          || (
            resource.data.clube_id is string
            && resource.data.clube_id.size() > 0
            && clubExists(resource.data.clube_id)
            && isMySchoolLegacyAware(
              clubData(resource.data.clube_id).escola_id,
              clubData(resource.data.clube_id).escola_nome
            )
          )
        )
        && request.resource.data.clube_id == resource.data.clube_id
        && request.resource.data.solicitante_id == resource.data.solicitante_id
        && resource.data.status == 'pendente'
        && request.resource.data.status is string
        && request.resource.data.status in ['aceita', 'recusada'];

      allow delete: if false;
    }

    // ─── Fórum: Tópicos ──────────────────────────────────
    match /forum_topicos/{topicId} {
      allow read: if true;

      allow create: if isSignedIn()
        && request.resource.data.clube_id is string
        && request.resource.data.titulo is string
        && request.resource.data.autor_id == request.auth.uid
        && (
          isMyClub(request.resource.data.clube_id)
          || isExternalMember(request.resource.data.clube_id)
        );

      // Mentor ou autor do tópico podem atualizar tudo
      // Qualquer usuário autenticado pode atualizar contadores (validação server-side)
      allow update: if isSignedIn() && (
        (isMentor() && isMyClub(resource.data.clube_id))
        || request.auth.uid == resource.data.autor_id
        || request.resource.data.clube_id == resource.data.clube_id // Permitir qualquer update mantendo o clube
      );

      allow delete: if isSignedIn()
        && (
          (isMentor() && isMyClub(resource.data.clube_id))
          || isExternalMember(resource.data.clube_id)
        );
    }

    // ─── Fórum: Mensagens ────────────────────────────────
    match /forum_mensagens/{msgId} {
      allow read: if true;

      // Criar mensagens: apenas usuários autenticados (validação server-side)
      // O servidor valida permissões, bans, suspensões, mutações, etc.
      allow create: if isSignedIn()
        && request.resource.data.topico_id is string
        && request.resource.data.clube_id is string
        && request.resource.data.autor_id is string
        && request.resource.data.conteudo is string
        && request.resource.data.createdAt is timestamp;

      // Editar: apenas o autor, mentor do clube, ou membro externo do clube
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.autor_id
        || (isMentor() && isMyClub(resource.data.clube_id))
        || isExternalMember(resource.data.clube_id)
      );

      // Deletar: apenas o autor, mentor do clube, ou membro externo do clube
      allow delete: if isSignedIn() && (
        request.auth.uid == resource.data.autor_id
        || (isMentor() && isMyClub(resource.data.clube_id))
        || isExternalMember(resource.data.clube_id)
      );
    }

    // ─── Fórum: Estado de Moderação ──────────────────────
    match /forum_user_moderation_state/{docId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isMentor();
    }

    // ─── Fórum: Silenciamentos de Tópicos ────────────────
    match /forum_topic_mutes/{docId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isMentor();
    }

    // ─── Fórum: Solicitações de Entrada ──────────────────
    match /forum_solicitacoes/{reqId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && request.resource.data.solicitante_id == request.auth.uid
        && request.resource.data.clube_id is string;

      allow update: if isSignedIn()
        && isMentor()
        && isMyClub(resource.data.clube_id);
    }

    // ─── Fórum: Membros Externos ─────────────────────────
    match /forum_membros_externos/{memId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && isMentor()
        && isMyClub(request.resource.data.clube_id);

      allow delete: if isSignedIn()
        && isMentor()
        && isMyClub(resource.data.clube_id);
    }

    // ─── Fórum: Mensagens Excluídas (Auditoria) ──────────
    match /forum_mensagens_excluidas/{docId} {
      allow read: if isSignedIn() && isMentor();

      allow create: if isSignedIn();

      allow update, delete: if false;
    }

    // ─── Fórum: Logs de Auditoria ──────────────────────
    match /forum_audit_logs/{logId} {
      allow read: if isSignedIn() && isMentor();

      allow create: if isSignedIn();

      allow update, delete: if false;
    }

    // ─── Fórum: Alertas de Moderação para Mentores ─────
    match /forum_moderation_alerts/{alertId} {
      allow read: if isSignedIn()
        && (
          request.auth.uid == resource.data.recipient_id
          || (isMentor() && isMyClub(resource.data.clube_id))
        );

      allow update: if isSignedIn()
        && (
          request.auth.uid == resource.data.recipient_id
          || (isMentor() && isMyClub(resource.data.clube_id))
        )
        && request.resource.data.recipient_id == resource.data.recipient_id
        && request.resource.data.clube_id == resource.data.clube_id;

      allow create, delete: if false;
    }

    match /{document=**} {
      allow read: if false;
      allow write: if false;
    }
  }
} 

